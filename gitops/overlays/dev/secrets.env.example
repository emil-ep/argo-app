# Backend Secrets Configuration
# Copy this file to secrets.env and fill in your actual values
# DO NOT commit secrets.env to version control

# Database credentials (must match postgres-secret)
database.user=postgres
database.password=CHANGE_ME_DATABASE_PASSWORD

# JWT secret for authentication (use a strong random string)
jwt.secret=CHANGE_ME_JWT_SECRET

# Instana configuration for backend APM tracing
# Get these from your Instana account: Settings > Agent Keys
#
# For Instana SaaS (most common):
#   - Agent Host: ingress-red-saas.instana.io (or your region's endpoint)
#   - Agent Port: 42699 (default Instana serverless port)
#   - Agent Key: Get from Instana UI > Settings > Agent Keys
#
# Example endpoints by region:
#   - US: ingress-red-saas.instana.io
#   - EU: ingress-blue-saas.instana.io
#   - Asia Pacific: ingress-pink-saas.instana.io
#
instana.agent.host=ingress-red-saas.instana.io
instana.agent.port=42699
instana.agent.key=CHANGE_ME_INSTANA_AGENT_KEY
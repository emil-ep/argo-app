# Backend Secrets Configuration
# Copy this file to secrets.env and fill in your actual values
# DO NOT commit secrets.env to version control

# Database credentials (must match postgres-secret)
database.user=postgres
database.password=CHANGE_ME_DATABASE_PASSWORD

# JWT secret for authentication (use a strong random string)
jwt.secret=CHANGE_ME_JWT_SECRET

# Instana agent key for backend APM tracing
# Get this from your Instana account: Settings > Agent Keys
instana.agent.key=CHANGE_ME_INSTANA_AGENT_KEY